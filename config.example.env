# Example configuration for local testing

# Telegram Bot Configuration
TG_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890
TG_ADMIN_IDS=123456789,987654321

# X-ray Server Configuration
# XRAY_API_URL is the X-UI panel base URL (no trailing /api): the bot calls
# {XRAY_API_URL}/login and {XRAY_API_URL}/xui/API/... under it.
XRAY_USER=admin
XRAY_PASSWORD=password123
XRAY_API_URL=http://localhost:8080
XRAY_SUB_URL_PREFIX=http://localhost:8080/sub

# Logging Configuration
LOG_LEVEL=debug